NEXT_PUBLIC_SITE_URL=https://example.com

# Backend API base URL
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_USE_FALLBACK_DATA=false

# Optional endpoint overrides
NEXT_PUBLIC_PROPERTIES_ENDPOINT=/properties
NEXT_PUBLIC_PROJECTS_ENDPOINT=/projects
NEXT_PUBLIC_BLOG_ENDPOINT=/blog-posts
NEXT_PUBLIC_SETTINGS_CITIES_ENDPOINT=/settings/cities
NEXT_PUBLIC_SETTINGS_FEATURES_ENDPOINT=/settings/features
NEXT_PUBLIC_CONTACT_ENDPOINT=/contact
NEXT_PUBLIC_CONTACT_PROPERTY_ENDPOINT=/contact/property/:id
NEXT_PUBLIC_CONTACT_PROJECT_ENDPOINT=/contact/project/:id
